# Copy to .env.local (or .env) and fill in real values. Do not commit secrets.
# cp .env.example .env.local

# OpenAI-compatible API base URL (path often ends with /v1 — follow your provider)
VITE_OPENCLAW_GEMINI_BASE_URL=https://your-model-host.example.com/v1

# Embedded in the client bundle (Vite). Use a server-side proxy if the key must stay off-device.
VITE_OPENCLAW_GEMINI_API_KEY=

# Optional metadata written into the generated OpenClaw config JSON
VITE_OPENCLAW_LAST_TOUCHED_AT=2026-04-12T00:00:00.000Z
VITE_OPENCLAW_LAST_TOUCHED_VERSION=2026.1.0
